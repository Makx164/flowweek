# Firebase — https://console.firebase.google.com
# 1. Neues Projekt anlegen
# 2. "Web App" hinzufügen
# 3. Authentication → Sign-in method → Google & Apple aktivieren
# 4. Firestore Database erstellen (Produktionsmodus)
# 5. Diese Werte aus den Projekteinstellungen kopieren

VITE_FIREBASE_API_KEY=AIzaSy...
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project
VITE_FIREBASE_APP_ID=1:000000000:web:abc123

# Ohne diese Variablen läuft die App im Offline-Modus (localStorage).
# Für Vercel: diese Keys unter Settings → Environment Variables eintragen.
